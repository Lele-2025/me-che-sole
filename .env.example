# Copia questo file in .env (mai committato, vedi .gitignore) e
# compila con i valori reali da Console Firebase → Impostazioni
# progetto → Le tue app → Web.
#
# Nota: l'apiKey di Firebase per il Web NON è un segreto — è pensato
# per stare nel bundle client, la sicurezza vera è nelle Firestore
# Security Rules (firestore.rules), non in questa chiave.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Chiave pubblicabile Stripe (Sviluppatori → Chiavi API) — non è un
# segreto, è pensata per stare nel bundle client, come l'apiKey Firebase.
# La chiave segreta (sk_test_...) NON va mai qui: vive solo nella
# config delle Cloud Functions (vedi functions/README.md).
VITE_STRIPE_PUBLISHABLE_KEY=
