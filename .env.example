# Copia questo file in .env (mai committato, vedi .gitignore) e
# compila con i valori reali da Console Firebase → Impostazioni
# progetto → Le tue app → Web.
#
# Nota: l'apiKey di Firebase per il Web NON è un segreto — è pensato
# per stare nel bundle client, la sicurezza vera è nelle Firestore
# Security Rules (firestore.rules), non in questa chiave.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
